# Copy to .env and fill in values. Never commit .env.

# --- Required ---
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/
PORT=8000

# JWT signing (must match deployment; do not use defaults in production)
JWT_SECRET_KEY=
# Legacy alias read by constants.py (optional if JWT_SECRET_KEY is set)
JWT_SECRET=

# Metered (video rooms)
METERED_SECRET_KEY=
METERED_DOMAIN=

# --- Optional: AI session summaries ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Optional: email (admin / notifications) ---
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Optional: AWS / S3 ---
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
BUCKET_NAME=

# --- Optional: app ---
PROD=
APP_NAME=
TOKEN_VALIDITY=7
