# Copy to .env and fill in values. Never commit .env.

# --- Required ---
DATABASE_URL=mongodb+srv://user:pass@cluster.mongodb.net/
PORT=8000

# JWT signing — single secret for Flask-REST JWT and room/participant tokens (socket_tokens.py)
# Must match deployment; do not commit real values or use defaults in production
JWT_SECRET_KEY=
# Legacy alias read by constants.py (optional if JWT_SECRET_KEY is set)
JWT_SECRET=

# Metered (video rooms)
METERED_SECRET_KEY=
METERED_DOMAIN=

# --- Optional: AI session summaries & transcript pipeline ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Transcripts: POST /api/meeting_ai/transcript → meeting_transcripts → async summary → meeting_reports (structured_note)

# Phase 3 — meetings_ai (clinical docs, GridFS, audit)
# POST /api/meetings_ai/generate — requires consent when MEETINGS_AI_REQUIRE_CONSENT=true
MEETINGS_AI_REQUIRE_CONSENT=true
# Retention hint stored on report rows (days from creation)
MEETINGS_AI_RETENTION_DAYS=2555

# --- Optional: email (admin / notifications) ---
SMTP_SERVER=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# --- Optional: AWS / S3 ---
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
BUCKET_NAME=

# --- Optional: app ---
PROD=
APP_NAME=
TOKEN_VALIDITY=7
